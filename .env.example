# Vikpix API
SERVER_PORT=8080
# PostgreSQL - Vikpix application database
POSTGRES_DB=vikpix
POSTGRES_USER=vikpix
POSTGRES_PASSWORD=vikpix
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/vikpix
SPRING_DATASOURCE_USERNAME=vikpix
SPRING_DATASOURCE_PASSWORD=vikpix
SPRING_JPA_HIBERNATE_DDL_AUTO=update
# Keycloak admin user - development only
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
# PostgreSQL - Keycloak internal database
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak
KC_DB=postgres
KC_DB_URL_HOST=keycloak-db
KC_DB_URL_DATABASE=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak
KC_HTTP_ENABLED=true
KC_HOSTNAME_STRICT=false
KC_HOSTNAME=http://localhost:8081
KC_HOSTNAME_STRICT=false
KC_HOSTNAME_STRICT_HTTPS=false
KC_PROXY_HEADERS=xforwarded
KC_HTTP_ENABLED=true
# Keycloak realm/client used by the API
KEYCLOAK_REALM=vikpix
KEYCLOAK_AUTH_SERVER_URL=http://keycloak:8080
KEYCLOAK_PUBLIC_AUTH_SERVER_URL=http://localhost:8081
APP_BACKEND_URL=http://localhost:8080
APP_FRONTEND_URL=http://localhost:5173
KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/vikpix
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/vikpix/protocol/openid-connect/certs
KEYCLOAK_ADMIN_CLIENT_ID=vikpix-api
KEYCLOAK_ADMIN_CLIENT_SECRET=replace-with-vikpix-api-client-secret
# Frontend OAuth client configured in Keycloak
VIKPIX_WEB_CLIENT_ID=vikpix-web
VIKPIX_WEB_ORIGIN=http://localhost:5173

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app
MAIL_FROM=no-reply@vikpix.com
FRONTEND_URL=http://localhost:5173
